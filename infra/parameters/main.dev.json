{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "location": {
      "value": "denmarkeast"
    },
    "namePrefix": {
      "value": "Dev-"
    },
    "logicAppName": {
      "value": "Alert_Router"
    },
    "logicAppRequestTriggerName": {
      "value": "When_an_HTTP_request_is_received"
    },
    "actionGroupName": {
      "value": "Trigger Alert Router Logic App"
    },
    "actionGroupShortName": {
      "value": "RouteAlert"
    },
    "actionGroupLocation": {
      "value": "SwedenCentral"
    },
    "actionGroupLogicAppReceiverName": {
      "value": "Trigger alert router"
    },
    "deployMetricAlert": {
      "value": true
    },
    "metricAlertName": {
      "value": "simplealert-metric-alert"
    },
    "metricNamespace": {
      "value": "Microsoft.Compute/virtualMachines"
    },
    "metricName": {
      "value": "Percentage CPU"
    },
    "metricTimeAggregation": {
      "value": "Average"
    },
    "metricOperator": {
      "value": "GreaterThan"
    },
    "metricThreshold": {
      "value": 80
    },
    "metricAlertSeverity": {
      "value": 2
    },
    "metricEvaluationFrequency": {
      "value": "PT1M"
    },
    "metricWindowSize": {
      "value": "PT5M"
    },
    "useCommonAlertSchema": {
      "value": true
    },
    "metricAutoMitigate": {
      "value": true
    },
    "metricAlertEnabled": {
      "value": true
    },
    "grantLogicAppSubscriptionReader": {
      "value": true
    },
    "tags": {
      "value": {
        "Workload": "AlertRouting",
        "managedBy": "bicep"
      }
    }
  }
}